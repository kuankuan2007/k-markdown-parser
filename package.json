{
  "name": "@kuankuan/k-markdown-parser",
  "version": "1.3.1",
  "description": "a Markdown parser",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**/*",
    "lint:fix": "elint src/**/* --fix",
    "format": "prettier --write src/**/*",
    "test": "rolldown -c rolldown.config.test.ts && node ./test/dist/index.js",
    "build": "rolldown -c rolldown.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kuankuan2007/k-markdown-parser.git"
  },
  "homepage": "https://github.com/kuankuan2007/k-markdown-parser",
  "bugs": {
    "url": "https://github.com/kuankuan2007/k-markdown-parser/issues"
  },
  "author": "kuankuan",
  "license": "MulanPSL-2.0",
  "types": "types/index.d.ts",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "rolldown": "^1.0.0-rc.13",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "keywords": [
    "markdown",
    "parser",
    "kuankuan"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "iife": "./dist/index.iife.min.js"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "default": "./dist/*.mjs",
      "types": "./dist/*.d.ts"
    }
  },
  "unpkg": "dist/index.iife.min.js",
  "jsdelivr": "dist/index.iife.min.js"
}
