{
  "name": "@kuankuan/k-markdown-parser",
  "version": "1.2.1-post1",
  "description": "a Markdown parser",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**/*",
    "lint:fix": "elint src/**/* --fix",
    "format": "prettier --write src/**/*",
    "test": "rolldown -c rolldown.config.test.ts && node ./test/dist/index.js",
    "build": "tsc && rolldown -c rolldown.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kuankuan2007/k-markdown-parser.git"
  },
  "homepage": "https://github.com/kuankuan2007/k-markdown-parser",
  "bugs": {
    "url": "https://github.com/kuankuan2007/k-markdown-parser/issues"
  },
  "author": "kuankuan",
  "license": "MulanPSL-2.0",
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "rolldown": "^1.0.0-rc.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "keywords": [
    "markdown",
    "parser",
    "kuankuan"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "unpkg": "dist/index.iife.min.js",
  "jsdelivr": "dist/index.iife.min.js"
}
